# ─── Clerk (https://dashboard.clerk.com) ──────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Plaid (https://dashboard.plaid.com/developers/keys) ──────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | development | production
PLAID_ENV=sandbox

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/financeos

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Anthropic (https://console.anthropic.com) ───────────────────────────────
# NEVER expose this key in the browser — backend only
ANTHROPIC_API_KEY=sk-ant-...

# ─── API ──────────────────────────────────────────────────────────────────────
# Internal API URL (used by Next.js server-side)
API_URL=http://localhost:3001
# Public API URL (exposed to browser — only safe public endpoints)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
PORT=3001
